{
  "name": "st6-weekly-commit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Weekly Commit Module — micro-frontend replacing 15Five with enforced RCDO alignment",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0",
    "yarn": ">=1.22.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "e2e"
  ],
  "scripts": {
    "dev": "nx run-many --target=serve --parallel=3",
    "dev:host": "nx serve pa-host",
    "dev:remote": "nx serve weekly-commit-remote",
    "dev:api": "cd services/weekly-commit-api && ./gradlew bootRun --args='--spring.profiles.active=dev'",
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "test:api": "cd services/weekly-commit-api && ./gradlew test jacocoTestReport jacocoTestCoverageVerification",
    "lint": "nx run-many --target=lint",
    "lint:fix": "nx run-many --target=lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "nx run-many --target=typecheck",
    "e2e": "nx run e2e:e2e",
    "e2e:open": "cd e2e && yarn cypress open",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v && yarn infra:up",
    "seed": "cd services/weekly-commit-api && ./gradlew bootRun --args='--spring.profiles.active=dev,seed'",
    "ci": "yarn format:check && yarn lint && yarn typecheck && yarn test && yarn test:api && yarn build"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@nx/eslint": "20.3.0",
    "@nx/eslint-plugin": "20.3.0",
    "@nx/js": "20.3.0",
    "@nx/react": "20.3.0",
    "@nx/vite": "20.3.0",
    "@nx/workspace": "20.3.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "20.11.5",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.3",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "msw": "^2.13.5",
    "nx": "20.3.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.18.2"
  },
  "packageManager": "yarn@1.22.22",
  "msw": {
    "workerDirectory": [
      "apps/weekly-commit-remote/public",
      "apps/pa-host/public"
    ]
  }
}
